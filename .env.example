SPRING_PROFILES_ACTIVE=local

LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5433
LOCAL_POSTGRES_DB=tour_local
LOCAL_POSTGRES_USER=tour
LOCAL_POSTGRES_PASSWORD=tour

DUMMY_PLACE_SEED_ENABLED=false

KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
TOUR_API_KEY=your-tour-api-key
TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
TOUR_API_MOBILE_OS=ETC
TOUR_API_MOBILE_APP=tour-server
TOUR_API_PLACE_INGESTION_ENABLED=false
TOUR_API_AREA_CODE=6
TOUR_API_CONTENT_TYPE_IDS=12,14,15,28,32,38,39
TOUR_API_PAGE_SIZE=100
TOUR_API_MAX_PAGES=1

# TourAPI 매일 자동 적재. 부팅 시 1회 적재(TOUR_API_PLACE_INGESTION_ENABLED)와는 별개 스위치다.
# CRON은 Spring 6자리(초 분 시 일 월 요일), 기준 시간대는 Asia/Seoul.
TOUR_API_INGESTION_SCHEDULER_ENABLED=false
TOUR_API_INGESTION_CRON=0 0 4 * * *
ODSAY_ENABLED=false
ODSAY_BASE_URL=https://api.odsay.com
ODSAY_API_KEY=your-odsay-api-key
BUSAN_BIMS_ENABLED=false
BUSAN_BIMS_BASE_URL=https://apis.data.go.kr/6260000/BusanBIMS
BUSAN_BIMS_API_KEY=your-busan-bims-api-key
TMAP_WALKING_ENABLED=false
TMAP_BASE_URL=https://apis.openapi.sk.com
SKT_API_KEY=your-skt-api-key
BUSAN_METRO_API_KEY=your-busan-metro-api-key
WEATHER_API_KEY=your-weather-api-key
